# Kopiere nach .env.local und trage deinen Schlüssel ein (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Öffentliche Basis-URL nach Deploy (Vercel etc.) — für Metadaten/PWA; lokal weglassen oder http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://dein-projekt.vercel.app

# Optional: Standard im Code ist gemini-2.5-pro. Schneller/günstiger: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro

# --- Upload-Limits (Deployment) ---
# Server: max. PDF in MB. Ohne gesetzte Variable gilt auf Vercel automatisch 4 MB (Serverless-Body-Limit).
# Lokal ohne VERCEL: Standard 50 MB.
# MAX_PDF_MB=50
#
# Client (Build-Zeit): muss zum Server-Limit passen. Auf Vercel setzt next.config ohne diese Variable 4.
# NEXT_PUBLIC_MAX_UPLOAD_MB=50

# --- Rate-Limit (pro Server-Instanz / IP) ---
# RATE_LIMIT_MAX=12
# RATE_LIMIT_WINDOW_MS=60000

# --- Server-Historie (optional, SQLite lokal) ---
# Ohne DATABASE_URL: nur Browser-localStorage. Mit SQLite werden Analysen zusätzlich serverseitig gespeichert.
# DATABASE_URL="file:./dev.db"
# Danach: npx prisma migrate dev
#
# --- Auth (serverseitige Historie über Geräte, mit DATABASE_URL) ---
# Mindestens 32 Zeichen, z. B. openssl rand -hex 32
# AUTH_SECRET=12341234123412341234123412341234
#
# --- Telegram (optional): Log-PDF zusätzlich per Bot an deinen Chat senden ---
# Bot bei @BotFather anlegen → Token hier. Chat-ID: Bot schreiben lassen, dann z. B. https://api.telegram.org/bot<TOKEN>/getUpdates (oder @userinfobot).
# Beide Werte müssen gesetzt sein, sonst bleibt die Checkbox in der App deaktiviert.
# In Vercel: Wert ohne Anführungszeichen einfügen; nach Änderung Redeploy. Test: https://api.telegram.org/bot<DEIN_TOKEN>/getMe muss "ok":true liefern.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
